# ── .streamlit/secrets.toml.example ─────────────────────────────────────────
# Copie este arquivo para .streamlit/secrets.toml e preencha os valores.
# O arquivo secrets.toml está no .gitignore — nunca suba para o GitHub.
#
# No Streamlit Community Cloud: cole o conteúdo em
# App Settings → Secrets (formato TOML idêntico a este).
# ─────────────────────────────────────────────────────────────────────────────

SUPABASE_URL = "postgresql://usuario:senha@host:5432/banco"
