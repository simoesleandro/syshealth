# ── SYS.HEALTH — Secrets (Streamlit Community Cloud) ─────────────────────────
#
# ONDE COLAR:
#   share.streamlit.io → seu app → Settings (⚙) → aba Secrets → cole tudo abaixo
#
# LOCAL (desenvolvimento):
#   Copie para .streamlit/secrets.toml (está no .gitignore — nunca commitar)
#
# FORMATO: TOML — chave = "valor" entre aspas duplas
# ─────────────────────────────────────────────────────────────────────────────


# ══════════════════════════════════════════════════════════════════════════════
# OBRIGATÓRIO — banco de dados (Supabase PostgreSQL)
# ══════════════════════════════════════════════════════════════════════════════
# Supabase → Project Settings → Database → Connection string → URI
# Use a URI com senha (não a pooler, a menos que você saiba o que está fazendo).

SUPABASE_URL = "postgresql://postgres:SUA_SENHA@db.xxxxxxxxxxxx.supabase.co:5432/postgres"


# ══════════════════════════════════════════════════════════════════════════════
# RECOMENDADO — IA Coach + análise de fotos (Gemini)
# ══════════════════════════════════════════════════════════════════════════════
# Google AI Studio → API Keys → Create API key

GEMINI_API_KEY = "AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"


# ══════════════════════════════════════════════════════════════════════════════
# OPCIONAL — Google Calendar (agenda na sidebar)
# ══════════════════════════════════════════════════════════════════════════════
# Rode UMA VEZ localmente:  python get_gcal_token.py
# Copie os três valores que o script imprimir / que estiverem no .env

GOOGLE_CLIENT_ID = "123456789012-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET = "GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx"
GOOGLE_REFRESH_TOKEN = "1//0gXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"


# ══════════════════════════════════════════════════════════════════════════════
# OPCIONAL — Hevy (sync de treinos no dashboard)
# ══════════════════════════════════════════════════════════════════════════════
# Hevy app → Settings → API → Generate API key

HEVY_API_KEY = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"


# ══════════════════════════════════════════════════════════════════════════════
# OPCIONAL — Zepp / Amazfit (botão 🔄 sync manual no dashboard)
# ══════════════════════════════════════════════════════════════════════════════
# Mesmos valores do bot Fly.io. Auto-sync às 07h BRT roda só no worker;
# no Streamlit Cloud o sync é manual (sidebar / treinos).

ZEPP_APP_TOKEN = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
ZEPP_USER_ID = "1234567890"


# ══════════════════════════════════════════════════════════════════════════════
# OPCIONAL — USDA FoodData Central (busca nutricional; default = DEMO_KEY)
# ══════════════════════════════════════════════════════════════════════════════

# USDA_API_KEY = "SUA_CHAVE_USDA"


# ══════════════════════════════════════════════════════════════════════════════
# NÃO COLOCAR AQUI (vão no Fly.io — bot Telegram, não no Streamlit Cloud)
# ══════════════════════════════════════════════════════════════════════════════
# TELEGRAM_TOKEN      →  fly secrets set TELEGRAM_TOKEN="..." --app syshealth-bot
#
# DB_PATH             →  só SQLite local; no Cloud use SUPABASE_URL acima
# ZEPP_AUTO_SYNC      →  desligado automaticamente no Streamlit Cloud
